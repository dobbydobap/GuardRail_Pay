# --- On-chain config (ContractService) ------------------------------------
# JSON-RPC endpoint (e.g. Monad testnet)
RPC_URL=https://testnet-rpc.monad.xyz

# Deployed contract addresses
AGENT_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
AGENT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# Signer keys. Agent signs requestPayment/createEscrow; verifier signs
# releaseEscrow. Read/listen works without them. NEVER commit real keys.
PRIVATE_KEY_AGENT=
PRIVATE_KEY_VERIFIER=

# Optional: JSON ABI overrides (default to src/contracts/*.abi.json)
# AGENT_VAULT_ABI_PATH=./src/contracts/AgentVault.abi.json
# AGENT_REGISTRY_ABI_PATH=./src/contracts/AgentRegistry.abi.json

# Optional: chainId hint for the provider
# CHAIN_ID=

# --- Ollama Cloud (OllamaClient, OpenAI-compatible) -----------------------
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com/v1
# Must be a model your key can access (see `GET <base>/models`). Demo default:
OLLAMA_MODEL=gpt-oss:120b
# Optional per-request timeout in ms (default 30000)
# OLLAMA_TIMEOUT_MS=30000

# --- Server ---------------------------------------------------------------
PORT=3000
